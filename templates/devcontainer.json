{
  "name": "myproject-builder",
  "build": { "dockerfile": "Dockerfile" },
  "workspaceFolder": "/workspace/project",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/project,type=bind",
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer/secrets,target=/run/secrets,type=bind,readonly",
    "source=${localWorkspaceFolder}/.devcontainer/var,target=/var/project,type=bind"
  ],
  "remoteUser": "root",
  "overrideCommand": true,
  "shutdownAction": "none"
}
